PORT=5000
MONGODB_URI=mongodb://localhost:27017/amtrak-tracker
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Nodemailer - Gmail example (use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Amtrak Tracker <your_email@gmail.com>"

CLIENT_URL=http://localhost:3000
